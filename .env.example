# RZUNA Backend Environment Template
# Copy to .env and fill in real values

NODE_ENV=production
PORT=3001
EXECUTION_MODE=dry_run

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Wallet (NEVER commit real keys)
WALLET_PRIVATE_KEY=
SOL_TREASURY_WALLET=
PLATFORM_FEE_WALLET=

# Jito MEV Protection
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
JITO_TIP_PAYMENT_ADDRESS=Cw8CFyM9FkoMi7K7Crf6HNQqf4uEMzpKw6QNghXLvLkY

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Geyser gRPC
GEYSER_PUBLIC_ENDPOINT=
GEYSER_PUBLIC_TOKEN=
GEYSER_VIP_ENDPOINT=
GEYSER_VIP_TOKEN=

# Observability
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=rzuna-prod
POSTHOG_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=

# CORS (comma-separated)
ALLOWED_ORIGINS=https://aivo.sh,https://trade.aivo.sh,https://vip.aivo.sh
