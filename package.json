{
  "name": "rzuna",
  "version": "1.9.0",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": "22"
  },
  "description": "",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:alpha": "turbo run test --filter=@rzuna/engine -- src/tests/backtest_alpha.test.ts",
    "test:dry-run": "turbo run test --filter=@rzuna/engine -- src/tests/simulation_dryrun.test.ts",
    "guardian": "./scripts/guardian.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "import-in-the-middle": "^3.0.0",
    "k6": "^0.0.0",
    "prettier": "^3.8.1",
    "require-in-the-middle": "^8.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.18.1",
      "elliptic": "6.6.1",
      "bigint-buffer": "1.1.5",
      "create-ecdh": "4.0.4",
      "react": "19.0.0",
      "react-dom": "19.0.0",
      "@types/react": "19.0.0",
      "@types/react-dom": "19.0.0",
      "lodash-es": "4.18.1",
      "tiny-secp256k1": "2.2.4",
      "@trezor/utxo-lib": "2.5.0",
      "glob": "13.0.6",
      "rimraf": "6.1.3",
      "uuid": "13.0.0",
      "lodash.isequal": "4.5.0",
      "@metamask/sdk": "0.34.0",
      "next": "16.2.2",
      "@walletconnect/universal-provider": "2.23.9",
      "@walletconnect/sign-client": "2.23.9"
    },
    "publicHoistPattern": [
      "*require-in-the-middle*",
      "*import-in-the-middle*"
    ]
  }
}
